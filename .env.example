# ─── Kafka (local = equivalente a Kinesis) ───────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=consent-events-raw
KAFKA_TOPIC_PROCESSED=consent-events-processed
KAFKA_CONSUMER_GROUP=consent-processor

# ─── Schema Registry (local = equivalente a Glue Schema Registry) ───
SCHEMA_REGISTRY_URL=http://localhost:8081
SCHEMA_NAME=consent
SCHEMA_NAMESPACE=com.healthcare.consent

# ─── MinIO (local = equivalente a S3) ────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=healthcare-raw
MINIO_BUCKET_PROCESSED=healthcare-processed

# ─── DynamoDB Local ──────────────────────────────────────────
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_REGION=us-east-1
DYNAMODB_TABLE=consent-state
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ─── Producer settings ───────────────────────────────────────
EVENTS_PER_SECOND=5
PRODUCER_BATCH_SIZE=10

# ─── Ambiente ────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=INFO